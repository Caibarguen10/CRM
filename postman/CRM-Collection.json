							"listen": "test",
							"script": {
								"exec": [
									"// Si eres Admin, debería ser 200",
									"// Si eres Asesor o Auditor, debería ser 403",
									"pm.test(\"Status code is 200 or 403\", function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 403]);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
